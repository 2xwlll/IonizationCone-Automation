import numpy as np
from astropy.io import fits
from scipy.ndimage import gaussian_filter
import torch

EPS = 1e-10

# --- CONFIG ---

LINE_CATALOG = {
    "OIII_5007": {"wavelength": 5007.0},
    "Ha_6563": {"wavelength": 6563.0}
}

RATIO_DEFS = {
    "OIII_Ha": ("OIII_5007", "Ha_6563")
}

TILE_SIZE = 64   # spatial size for UNet
DEPTH = 10       # number of spectral slices around line
SMOOTH_SIGMA = 1.0

# --- FITS I/O ---

def load_cube(fits_path):
    """Load FITS cube. Returns (cube, header)."""
    with fits.open(fits_path) as hdul:
        cube = hdul["DATA"].data      # shape: (λ, y, x)
        header = hdul["DATA"].header
    return cube, header

def wavelength_to_index(header, target_wavelength):
    """Convert wavelength to spectral index using FITS WCS."""
    crval = header["CRVAL3"]
    crpix = header["CRPIX3"]
    cdelt = header.get("CDELT3", header.get("CD3_3", None))
    if cdelt is None:
        raise KeyError("No spectral dispersion keyword (CDELT3 or CD3_3) found")
    idx = (target_wavelength - crval) / cdelt + crpix
    return int(np.round(idx))

# --- FLUX EXTRACTION ---

def extract_line_slab(cube, header, wavelength, depth=DEPTH, smooth_sigma=SMOOTH_SIGMA):
    """Return a spectral slab of given depth around a line, smoothed spatially."""
    idx = wavelength_to_index(header, wavelength)
    half_depth = depth // 2
    start = max(idx - half_depth, 0)
    end = min(idx + half_depth + 1, cube.shape[0])
    slab = cube[start:end, :, :]  # shape: (depth, y, x)
    if smooth_sigma is not None:
        for i in range(slab.shape[0]):
            slab[i] = gaussian_filter(slab[i], smooth_sigma)
    return slab

def build_flux_slabs(cube, header, line_catalog):
    """Return dict of line_name -> 3D slabs (depth, y, x)."""
    flux_slabs = {}
    for line_name, props in line_catalog.items():
        print(f"Extracting {line_name}")
        flux_slabs[line_name] = extract_line_slab(cube, header, props["wavelength"])
    return flux_slabs

# --- RATIO MAPS ---

def build_ratio_slabs(flux_slabs, ratio_defs):
    """Return dict of ratio_name -> 3D slabs (depth, y, x)."""
    ratio_slabs = {}
    for name, (num, den) in ratio_defs.items():
        ratio_slabs[name] = flux_slabs[num] / (flux_slabs[den] + EPS)
    return ratio_slabs

# --- PERCENTILE CLIPPING ---

def percentile_clip(slab, low=5, high=95):
    """Clip extreme percentiles along spatial axes, per slice."""
    clipped = np.empty_like(slab)
    for i in range(slab.shape[0]):
        lo, hi = np.nanpercentile(slab[i], [low, high])
        clipped[i] = np.clip(slab[i], lo, hi)
    return clipped

# --- TILING ---

def tile_slab(slab, tile_size=TILE_SIZE):
    """
    Break 3D slab (depth, y, x) into tiles of shape (depth, tile_size, tile_size).
    Pads edges with edge values to fill incomplete tiles.
    """
    depth, ny, nx = slab.shape
    tiles = []
    for y in range(0, ny, tile_size):
        for x in range(0, nx, tile_size):
            tile = slab[:, y:y+tile_size, x:x+tile_size]
            pad_y = tile_size - tile.shape[1]
            pad_x = tile_size - tile.shape[2]
            if pad_y > 0 or pad_x > 0:
                tile = np.pad(tile, 
                              ((0,0), (0,pad_y), (0,pad_x)),
                              mode='edge')
            tiles.append(tile)
    return np.array(tiles)  # shape: (num_tiles, depth, tile_size, tile_size)

# --- FULL PIPELINE ---

def run_pipeline(fits_path, tile_size=TILE_SIZE, depth=DEPTH):
    cube, header = load_cube(fits_path)

    # 1️⃣ Extract line slabs
    flux_slabs = build_flux_slabs(cube, header, LINE_CATALOG)

    # 2️⃣ Compute ratio slabs
    ratio_slabs = build_ratio_slabs(flux_slabs, RATIO_DEFS)

    # 3️⃣ Clip extreme values for numerical stability
    clipped_slabs = {name: percentile_clip(slab) for name, slab in ratio_slabs.items()}

    # 4️⃣ Tile slabs spatially
    tiled_slabs = {name: tile_slab(slab, tile_size=tile_size) for name, slab in clipped_slabs.items()}

    # 5️⃣ Convert to PyTorch tensors, shape: (num_tiles, channels=1, depth, tile_size, tile_size)
    pytorch_tiles = {name: torch.tensor(tiles, dtype=torch.float32)[:, None, :, :, :] 
                     for name, tiles in tiled_slabs.items()}

    return {
        "flux_slabs": flux_slabs,
        "ratio_slabs": ratio_slabs,
        "clipped_slabs": clipped_slabs,
        "tiled_slabs": tiled_slabs,
        "pytorch_tiles": pytorch_tiles
    }

# --- VISUALIZATION (optional) ---

import matplotlib.pyplot as plt

def visualize_slab(slab, slice_idx=0, title="Slab Slice"):
    """
    Show a single spatial slice from a 3D slab.
    """
    plt.figure(figsize=(6,6))
    plt.imshow(slab[slice_idx], origin='lower', cmap='inferno')
    plt.colorbar(label="Flux / Ratio")
    plt.title(f"{title} — slice {slice_idx}")
    plt.show()

# --- TEST RUN ---

if __name__ == "__main__":
    fits_path = "data/cubes/raw/real/MUSE_NGC4388/data/ADP.2022-04-05T21:35:50.711.fits"
    results = run_pipeline(fits_path)

    for name, tiles in results["pytorch_tiles"].items():
        print(f"{name} PyTorch tiles shape: {tiles.shape}")  # (num_tiles, 1, depth, 64, 64)

    # Example: visualize first tile of OIII/Hα ratio
    first_tile = results["clipped_slabs"]["OIII_Ha"][:, :TILE_SIZE, :TILE_SIZE]
    visualize_slab(first_tile, slice_idx=DEPTH//2, title="OIII/Hα first tile")
